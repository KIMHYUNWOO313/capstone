# OpenAI (GPT 설명)
OPENAI_API_KEY=
OPENAI_EXPLAIN_MODEL=gpt-4o-mini
OPENAI_NEWS_MODEL=gpt-4o-mini

# Firebase Admin JSON 서비스 계정 경로 (비우면 Firestore 미사용, Django DB만 사용)
FIREBASE_CREDENTIALS_PATH=

# Chronos-2 추론 스킵 (개발 시 true 권장 — 더미 예측)
CHRONOS_SKIP_INFERENCE=true

# 선택: GPT 설명에 넣을 뉴스·요약 UTF-8 파일 경로 (비우면 기상 위주만)
# AGRI_NEWS_CONTEXT_PATH=

# 선택: 외부 농업 실제가 API (구현 시 reconcile에서 우선 사용)
# AGRIDATA_API_URL=
# AGRIDATA_API_KEY=

# 외부 데이터 수집용 API 키
WEATHER_API=
OPINET_API=
KAMIS_API_KEY=
# KAMIS 사용자 ID. 미설정 시 'tester' 시도
# KAMIS_API_ID=
# 기상청 ASOS 일평균 관측소 ID(예: 108=서울). 빈 값이면 108 사용
# WEATHER_STN_IDS=108

# 매일 00:00(Asia/Seoul) 자동 수집 스케줄러
# AGRI_AUTO_FETCH_ENABLED=true
